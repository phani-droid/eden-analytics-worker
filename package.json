{
  "name": "eden-analytics-worker",
  "version": "5.56.3",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --check cloudflare-workers/eden-analytics.js && node --check cloudflare-workers/eden-conversion-coordinator.js",
    "test:worker": "node scripts/test-eden-analytics-worker-local.mjs",
    "test:coordinator": "node scripts/test-eden-conversion-coordinator-v556-local.mjs",
    "test": "npm run check && npm run test:worker && npm run test:coordinator",
    "dry-run": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler deploy --dry-run --config wrangler.jsonc --outdir .wrangler/dry-run",
    "deploy": "WRANGLER_LOG_PATH=.wrangler/wrangler.log wrangler deploy --config wrangler.jsonc"
  },
  "devDependencies": {
    "wrangler": "4.110.0"
  },
  "engines": {
    "node": ">=22"
  }
}
